# ─── Sistema Web Original ────────────────────────────────────────────────────
APP_TITLE=OWASP Verificator
APP_ENV=development
ADMIN_DASHBOARD_PASSWORD=owasp-admin-2026
DEMO_API_TOKEN=demo-token-12345
ADMIN_API_TOKEN=admin-token-67890
GITHUB_TOKEN=

# ─── API Microservice ─────────────────────────────────────────────────────────
API_TITLE=OWASP Verificador — Microservicio API
API_VERSION=1.0.0
API_PORT=8001

# Seguridad: false = sin auth (ideal para dev), true = requiere X-API-Key
REQUIRE_AUTH=false

# CORS: "*" = todos los orígenes, o lista separada por comas
ALLOWED_ORIGINS=*

# ─── Datos ───────────────────────────────────────────────────────────────────
# Ruta donde se guardan los scans (SQLite + JSON)
APP_DATA_PATH=

# ─── Cache de assets (opcional, para deploy) ──────────────────────────────────
ASSET_VERSION=
